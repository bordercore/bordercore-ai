#!/usr/bin/env bash
#
# Git pre-push hook
#
# Purpose:
# 1. Block pushes with frontend TypeScript type errors (tsc --noEmit).
#
# Usage:
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
WEBAPP_DIR="$REPO_ROOT/webapp"

echo "--- Starting Pre-push Checks ---"

cd "$WEBAPP_DIR"
if [ -d "node_modules" ]; then
  echo "Running TypeScript typecheck..."
  npm run -s typecheck
  echo "TypeScript typecheck passed."
else
  echo "Warning: node_modules not found. Skipping typecheck."
fi

echo "--- Pre-push Checks Finished Successfully ---"
exit 0
